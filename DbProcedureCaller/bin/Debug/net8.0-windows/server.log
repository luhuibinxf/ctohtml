                        WHEN 'EIS' THEN '内镜' 
                        WHEN 'PIS' THEN '病理'
                        WHEN 'NMS' THEN '核医学'
                        ELSE t.SYSTEM_SOURCE_NO 
                    END, '') AS 系统,
                    ISNULL(r.REPORTER_NAME, '') AS 报告医生,
                    ISNULL(r.REVIEWER_NAME, '') AS 审核
