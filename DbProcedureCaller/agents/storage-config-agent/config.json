{
  "name": "存储配置智能体",
  "description": "用于管理统计分析系统的存储过程配置，支持配置加载、参数映射和执行调度",
  "version": "1.0",
  "author": "System",
  "createdAt": "2026-05-05",
  "apiEndpoints": [
    {
      "name": "获取存储过程配置列表",
      "path": "/get-proc-configs",
      "method": "GET",
      "description": "获取所有已配置的存储过程列表"
    },
    {
      "name": "获取单个存储配置",
      "path": "/get-proc-config",
      "method": "GET",
      "description": "根据ID获取单个存储过程配置"
    },
    {
      "name": "保存存储配置",
      "path": "/save-proc-config",
      "method": "POST",
      "description": "保存或更新存储过程配置"
    },
    {
      "name": "删除存储配置",
      "path": "/delete-proc-config",
      "method": "POST",
      "description": "删除指定的存储过程配置"
    },
    {
      "name": "执行存储过程",
      "path": "/execute-stored-proc",
      "method": "POST",
      "description": "执行指定的存储过程"
    },
    {
      "name": "搜索存储过程",
      "path": "/search-stored-proc",
      "method": "POST",
      "description": "在数据库中搜索可用的存储过程"
    },
    {
      "name": "获取存储过程元数据",
      "path": "/get-proc-metadata",
      "method": "POST",
      "description": "获取存储过程的参数元数据"
    }
  ],
  "configSchema": {
    "id": {
      "type": "string",
      "required": true,
      "description": "配置唯一标识（小写字母+下划线）"
    },
    "name": {
      "type": "string",
      "required": true,
      "description": "显示名称"
    },
    "icon": {
      "type": "string",
      "required": false,
      "default": "fa-chart-bar",
      "description": "FontAwesome图标类名"
    },
    "procName": {
      "type": "string",
      "required": true,
      "description": "存储过程名称"
    },
    "templateName": {
      "type": "string",
      "required": false,
      "description": "自定义模板HTML文件名"
    },
    "parameters": {
      "type": "array",
      "required": false,
      "description": "参数配置数组",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "required": true,
            "description": "存储过程参数名（必须带@）"
          },
          "displayName": {
            "type": "string",
            "required": true,
            "description": "界面显示名称"
          },
          "type": {
            "type": "string",
            "required": true,
            "description": "参数类型：datetime/varchar/int"
          },
          "defaultValue": {
            "type": "string",
            "required": false,
            "description": "默认值"
          },
          "options": {
            "type": "string",
            "required": false,
            "description": "选项列表（逗号分隔）"
          },
          "isRequired": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "是否必填"
          },
          "isMultiple": {
            "type": "boolean",
            "required": false,
            "default": false,
            "description": "是否多选"
          },
          "description": {
            "type": "string",
            "required": false,
            "description": "参数描述"
          }
        }
      }
    },
    "enabled": {
      "type": "boolean",
      "required": true,
      "default": true,
      "description": "是否启用"
    },
    "sortOrder": {
      "type": "integer",
      "required": false,
      "default": 100,
      "description": "排序序号"
    }
  },
  "parameterTypeMapping": {
    "datetime": "date",
    "int": "number",
    "varchar": "text",
    "varchar_options": "select"
  },
  "optionsFormat": {
    "simple": "选项1,选项2,选项3",
    "keyValue": "0:全部,1:选项1,2:选项2"
  }
}